includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app

    # 5から始めて慣れたら上げていく
    level: 5

    excludePaths:
        # OpenAPIアノテーション専用クラス（ドキュメント生成のみ）
        - app/OpenApi

    ignoreErrors:
        # JsonResource は __get() でモデルのプロパティをプロキシするため
        # Larastan がモデル型を追跡できずに発生する誤検知を抑制
        - '#Access to an undefined property App\\Http\\Resources\\[^:]+::\$#'
        # TransientToken には delete() がないため method_exists チェックは正当
        - '#Call to function method_exists\(\) with Laravel\\Sanctum\\PersonalAccessToken and .delete. will always evaluate to true#'
        # HasMany リレーション越しにスコープを呼ぶパターン（例: $profile->jobs()->published()）
        - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Relations\\HasMany::published\(\)#'
        # $request->user() は Authenticatable として型付けされるが、
        # ルートには必ず App\Models\User が渡されるため誤検知を抑制
        -
            message: '#Access to an undefined property Illuminate\\Database\\Eloquent\\Model::#'
            path: app/Http/Controllers
        -
            message: '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::#'
            path: app/Http/Controllers
