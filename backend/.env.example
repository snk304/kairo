APP_NAME="Kairo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ============================================================
# Database
# ローカル: Docker Compose の PostgreSQL
# 本番: Supabase の Transaction mode 接続文字列
# ============================================================
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=matching_db
DB_USERNAME=postgres
DB_PASSWORD=password

# 本番のみ（Supabase Transaction mode URL）
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# ============================================================
# Cache / Session / Queue
# ローカル: Redis / 本番: database（Renderはファイル永続化不可のため）
# ============================================================
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# ============================================================
# Scout（全文検索）
# ローカル: meilisearch / 本番: database
# ============================================================
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterkey

# ============================================================
# File Storage
# ローカル: local / 本番: Supabase Storage（S3互換）
# ============================================================
FILESYSTEM_DISK=local

# 本番のみ（Supabase Storage）
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=kairo-uploads
# AWS_URL=https://<project>.supabase.co/storage/v1/object/public
# AWS_ENDPOINT=https://<project>.supabase.co/storage/v1/s3

# ============================================================
# CORS / Sanctum
# 本番: Vercel のデプロイURL（カンマ区切りで複数指定可）
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# ============================================================
# Mail
# ============================================================
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# Swagger
# ============================================================
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_UI_DOC_EXPANSION=none
